# =============================================================================
# AgentisOrchestra -- Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# --- Database ---
DB_NAME=agentis_orchestra
DB_USER=agentis
DB_PASSWORD=change-me-in-production
DB_PORT=5432

# --- Bridge (Agent Execution Engine) ---
BRIDGE_PORT=3847
BRIDGE_TOKEN=change-me-in-production
ADAPTER_MODE=cli           # cli (Pro sub, free) | sdk | api

# BRIDGE_URL -- how the app container reaches the bridge
# Local dev / Mac Mini:  http://localhost:3847  (default, both on host)
# VPS (Docker + host bridge): set via docker-compose environment or use host.docker.internal
# Only override if bridge is NOT on localhost
# BRIDGE_URL=http://localhost:3847

# --- App (Web UI) ---
APP_PORT=3000
NEXTAUTH_SECRET=change-me-in-production
AUTH_TOKEN=                  # Optional, leave blank

# --- Email Notifications (optional) ---
# SMTP config for sending approval/escalation notifications
# If not set, notifications are silently skipped
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Orchestra <noreply@yourcompany.com>
# NOTIFY_ADMIN_EMAIL=admin@yourcompany.com
# APP_URL=https://orchestra.yourcompany.com

# --- Security ---
# 32-byte key for AES-256-GCM encryption of provider API keys in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-in-production

# =============================================================================
# MODEL PROVIDERS
# CLI is always available (Pro subscription). Add API keys to unlock more models.
# =============================================================================

# Claude CLI -- Pro subscription (flat cost, no per-token)
# Just works if `claude` is installed and authenticated
CLAUDE_CLI_PATH=/usr/local/bin/claude

# Anthropic API -- for SDK adapter mode (per-token billing)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter -- 100+ models (GPT, Gemini, Llama, DeepSeek, Qwen, etc.)
# OPENROUTER_API_KEY=sk-or-...

# Perplexity -- web search with citations (research & fact-checking)
# PERPLEXITY_API_KEY=pplx-...

# OpenAI -- GPT-4o, o3 (direct API)
# OPENAI_API_KEY=sk-...
